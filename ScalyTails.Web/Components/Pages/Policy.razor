@page "/policy"
@rendermode InteractiveServer
@inject ITailscaleApiService Api
@inject IAppSettingsService AppSettings

<PageTitle>Policy — ScalyTails</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Policy</MudText>

@if (!Api.IsConfigured)
{
    <MudAlert Severity="Severity.Warning">No API key configured. Go to Settings to add one.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info">Policy page — coming soon.</MudAlert>
}
