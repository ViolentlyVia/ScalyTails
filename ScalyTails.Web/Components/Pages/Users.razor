@page "/users"
@rendermode InteractiveServer
@inject ITailscaleApiService Api
@inject IAppSettingsService AppSettings

<PageTitle>Users — ScalyTails</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Users</MudText>

@if (!Api.IsConfigured)
{
    <MudAlert Severity="Severity.Warning">No API key configured. Go to Settings to add one.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info">Users page — coming soon.</MudAlert>
}
