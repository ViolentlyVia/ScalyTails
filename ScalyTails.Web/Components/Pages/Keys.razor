@page "/keys"
@rendermode InteractiveServer
@inject ITailscaleApiService Api
@inject IAppSettingsService AppSettings

<PageTitle>Keys — ScalyTails</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Keys</MudText>

@if (!Api.IsConfigured)
{
    <MudAlert Severity="Severity.Warning">No API key configured. Go to Settings to add one.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info">Keys page — coming soon.</MudAlert>
}
