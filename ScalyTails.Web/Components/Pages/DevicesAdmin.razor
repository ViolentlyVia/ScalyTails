@page "/devices"
@rendermode InteractiveServer
@inject ITailscaleApiService Api
@inject IAppSettingsService AppSettings

<PageTitle>Devices — ScalyTails</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Devices</MudText>

@if (!Api.IsConfigured)
{
    <MudAlert Severity="Severity.Warning">No API key configured. Go to Settings to add one.</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Info">Devices page — coming soon.</MudAlert>
}
