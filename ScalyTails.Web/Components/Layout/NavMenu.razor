@implements IDisposable
@inject IAppSettingsService AppSettings

<MudNavMenu>

    @if (AppSettings.Settings.AdvancedMode)
    {
        <MudText Typo="Typo.caption" Class="px-4 pt-3 pb-1 mud-text-secondary">LOCAL</MudText>

        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            Overview
        </MudNavLink>
        <MudNavLink Href="/peers" Icon="@Icons.Material.Filled.Devices">
            Peers
        </MudNavLink>
        <MudNavLink Href="/exit-nodes" Icon="@Icons.Material.Filled.ExitToApp">
            Exit Nodes
        </MudNavLink>
        <MudNavLink Href="/subnet-routes" Icon="@Icons.Material.Filled.AccountTree">
            Subnet Routes
        </MudNavLink>
        <MudNavLink Href="/serve" Icon="@Icons.Material.Filled.Cloud">
            Serve &amp; Funnel
        </MudNavLink>
        <MudNavLink Href="/diagnostics" Icon="@Icons.Material.Filled.NetworkCheck">
            Diagnostics
        </MudNavLink>
        <MudNavLink Href="/taildrive" Icon="@Icons.Material.Filled.Folder">
            TailDrive
        </MudNavLink>
        <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
            Settings
        </MudNavLink>

        <MudDivider Class="my-2" />
        <MudText Typo="Typo.caption" Class="px-4 pb-1 mud-text-secondary">ADMIN (API key required)</MudText>

        <MudNavLink Href="/dns" Icon="@Icons.Material.Filled.Dns">
            DNS
        </MudNavLink>
        <MudNavLink Href="/devices" Icon="@Icons.Material.Filled.Computer">
            Devices
        </MudNavLink>
        <MudNavLink Href="/users" Icon="@Icons.Material.Filled.Group">
            Users
        </MudNavLink>
        <MudNavLink Href="/policy" Icon="@Icons.Material.Filled.Policy">
            Policy
        </MudNavLink>
        <MudNavLink Href="/logs" Icon="@Icons.Material.Filled.List">
            Logs
        </MudNavLink>
        <MudNavLink Href="/keys" Icon="@Icons.Material.Filled.Key">
            Keys
        </MudNavLink>
    }
    else
    {
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
        <MudNavLink Href="/peers" Icon="@Icons.Material.Filled.Devices">
            My Devices
        </MudNavLink>
        <MudNavLink Href="/exit-nodes" Icon="@Icons.Material.Filled.ExitToApp">
            VPN Exit Points
        </MudNavLink>
        <MudNavLink Href="/subnet-routes" Icon="@Icons.Material.Filled.AccountTree">
            Network Sharing
        </MudNavLink>
        <MudNavLink Href="/serve" Icon="@Icons.Material.Filled.Cloud">
            Share Services
        </MudNavLink>
        <MudNavLink Href="/diagnostics" Icon="@Icons.Material.Filled.NetworkCheck">
            Troubleshooting
        </MudNavLink>
        <MudNavLink Href="/taildrive" Icon="@Icons.Material.Filled.Folder">
            File Sharing
        </MudNavLink>
        <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
            Settings
        </MudNavLink>
    }

</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        AppSettings.Changed += OnSettingsChanged;
    }

    private void OnSettingsChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppSettings.Changed -= OnSettingsChanged;
    }
}
