<UserControl x:Class="ScalyTails.Views.KeysPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:models="clr-namespace:ScalyTails.Models">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="8,8,8,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Key" Width="24" Height="24" VerticalAlignment="Center"
                                         Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Auth Keys" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="14,6"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Load"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- No API key warning -->
        <materialDesign:Card Background="#FFB71C1C" Grid.Row="1" Margin="8,0,8,12" Padding="14"
                              Visibility="{Binding HasApiKey, Converter={StaticResource VisibleWhenFalse}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="API key required. Go to Settings to add one." Foreground="White"
                           Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Create form -->
        <materialDesign:Card Grid.Row="2" Margin="8,0,8,12" Padding="16">
            <StackPanel>
                <TextBlock Text="CREATE NEW KEY" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,12"/>
                <TextBox materialDesign:HintAssist.Hint="Description (optional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding NewKeyDescription, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <WrapPanel Margin="0,0,0,12">
                    <CheckBox Content="Reusable" IsChecked="{Binding NewKeyReusable}" Margin="0,0,24,0"/>
                    <CheckBox Content="Ephemeral" IsChecked="{Binding NewKeyEphemeral}" Margin="0,0,24,0"/>
                    <CheckBox Content="Preauthorized" IsChecked="{Binding NewKeyPreauthorized}"/>
                </WrapPanel>
                <Button Command="{Binding CreateKeyCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Padding="16,6"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Create Key"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- Created key display (shown only after key is created) -->
        <materialDesign:Card Grid.Row="3" Margin="8,0,8,12" Padding="16" Background="#FF1B5E20">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CreatedKeyValue}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="16" Height="16"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Copy this key now — it will not be shown again."
                               Foreground="White" FontWeight="Medium"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding CreatedKeyValue}" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="White" Background="#22FFFFFF"
                             BorderBrush="#55FFFFFF" BorderThickness="1"
                             Padding="8,6" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Command="{Binding CopyCreatedKeyCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Copy"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- Keys list -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Keys}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="10 6 10 6"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Created"
                                    Binding="{Binding Created, StringFormat='{}{0:yyyy-MM-dd}'}"
                                    Width="110" FontSize="12"/>
                <DataGridTextColumn Header="Expires" Binding="{Binding ExpiryDisplay}" Width="90" FontSize="12"/>
                <DataGridTemplateColumn Header="Actions" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:ApiAuthKey}">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Width="32" Height="32" Padding="0" ToolTip="Revoke key"
                                    Command="{Binding DataContext.DeleteKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="KeyRemove" Width="16" Height="16" Foreground="#FFEF5350"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
