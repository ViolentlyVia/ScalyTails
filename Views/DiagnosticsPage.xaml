<UserControl x:Class="ScalyTails.Views.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:vm="clr-namespace:ScalyTails.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="760">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Stethoscope" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Diagnostics" Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── Network Check ───────────────────────────────────────────── -->
            <TextBlock Text="NETWORK CHECK" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tests UDP, NAT type, IPv6, and DERP relay latency."
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding RunNetCheckCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircle" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Run Check"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Visibility>
                        <Binding Path="NetCheckDone" Converter="{StaticResource VisibleWhenTrue}"/>
                    </Visibility>

                    <StackPanel Visibility="{Binding NetCheckDone, Converter={StaticResource VisibleWhenTrue}}">
                        <UniformGrid Rows="1" Columns="3" Margin="0,0,0,16">
                            <Border Padding="12,10" Margin="0,0,8,0" CornerRadius="4"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <StackPanel>
                                    <TextBlock Text="UDP" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding NetCheckUdp}" FontWeight="Medium" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="12,10" Margin="0,0,8,0" CornerRadius="4"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <StackPanel>
                                    <TextBlock Text="IPv4" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding NetCheckIPv4}" FontWeight="Medium" Margin="0,4,0,0"
                                               FontFamily="Consolas" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="12,10" CornerRadius="4"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <StackPanel>
                                    <TextBlock Text="IPv6" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding NetCheckIPv6}" FontWeight="Medium" Margin="0,4,0,0"
                                               FontFamily="Consolas" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,16">
                            <Border Padding="12,10" Margin="0,0,8,0" CornerRadius="4"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <StackPanel>
                                    <TextBlock Text="NAT Type" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding NetCheckNat}" FontWeight="Medium" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="12,10" CornerRadius="4"
                                    Background="{DynamicResource MaterialDesignDivider}">
                                <StackPanel>
                                    <TextBlock Text="Preferred DERP" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock Text="{Binding NetCheckPreferredDerp}" FontWeight="Medium" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="DERP RELAY LATENCY" Style="{StaticResource MaterialDesignOverlineTextBlock}"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding DerpLatencies}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DerpLatency}">
                                    <Border Padding="10,6" Margin="0,0,8,8" CornerRadius="4"
                                            Background="{DynamicResource MaterialDesignDivider}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RegionId}" FontSize="11"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Display}" FontWeight="Medium" FontSize="13"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Ping ───────────────────────────────────────────────────── -->
            <TextBlock Text="PING PEER" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Hostname or Tailscale IP"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding PingTarget, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding PingCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding PingCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsPinging, Converter={StaticResource InverseBool}}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Wifi" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ping"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBox Text="{Binding PingOutput, Mode=OneWay}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextWrapping="Wrap" MinHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="{Binding PingOutput.Length, Converter={StaticResource VisibleWhenTrue}}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Whois ──────────────────────────────────────────────────── -->
            <TextBlock Text="WHOIS LOOKUP" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Tailscale IP address"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding WhoisTarget, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding WhoisCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding WhoisCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountSearch" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lookup"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBox Text="{Binding WhoisOutput, Mode=OneWay}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextWrapping="Wrap" MinHeight="80"
                             Visibility="{Binding WhoisOutput.Length, Converter={StaticResource VisibleWhenTrue}}"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Update + Bug Report ────────────────────────────────────── -->
            <UniformGrid Rows="1" Columns="2" Margin="0,0,0,0">
                <materialDesign:Card Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Update" Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Software Update" Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CheckUpdateCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                    Padding="12,6" Margin="0,0,8,0">
                                <TextBlock Text="Check"/>
                            </Button>
                            <Button Command="{Binding ApplyUpdateCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    IsEnabled="{Binding UpdateAvailable}"
                                    Padding="12,6">
                                <TextBlock Text="Update Now"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Bug" Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Bug Report" Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding BugReportId}" TextWrapping="Wrap" Margin="0,0,0,12"
                                   FontFamily="Consolas" FontSize="12"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                        <Button Command="{Binding GenerateBugReportCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="12,6" HorizontalAlignment="Left">
                            <TextBlock Text="Generate ID"/>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
