<UserControl x:Class="ScalyTails.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="680">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Settings" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── API Key ─────────────────────────────────────────────────── -->
            <TextBlock Text="TAILSCALE API KEY" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="KeyVariant" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="API key active" FontWeight="Medium"
                                   Visibility="{Binding ApiKeySet, Converter={StaticResource VisibleWhenTrue}}"
                                   Foreground="#FF4CAF50"/>
                        <TextBlock Text="No API key set — admin features disabled"
                                   Visibility="{Binding ApiKeySet, Converter={StaticResource VisibleWhenFalse}}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="Generate an API key at login.tailscale.com/admin/settings/keys then paste it below. Required for Devices, Users, DNS, Policy, Logs, and Keys pages."/>

                    <PasswordBox x:Name="ApiKeyBox"
                                 materialDesign:HintAssist.Hint="tskey-api-..."
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,8"
                                 PasswordChanged="ApiKeyBox_PasswordChanged"/>

                    <!-- Warn when user pastes a device auth key instead of an API access token -->
                    <Border Margin="0,0,0,8" Padding="10,8" CornerRadius="4"
                            Background="#1FFF5722"
                            BorderBrush="#FFFF5722" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeyTypeWarning}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="18" Height="18"
                                                     VerticalAlignment="Top" Margin="0,0,8,0"
                                                     Foreground="#FFFF5722"/>
                            <TextBlock Text="{Binding KeyTypeWarning}" TextWrapping="Wrap"
                                       Foreground="#FFFF5722"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                        </StackPanel>
                    </Border>

                    <TextBox materialDesign:HintAssist.Hint="Tailnet (use - for default)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Tailnet, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SaveApiKeyCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Padding="16,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Save Key"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding TestConnectionCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="16,8" Margin="0,0,8,0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Test Connection"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearApiKeyCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="16,8"
                                Visibility="{Binding ApiKeySet, Converter={StaticResource VisibleWhenTrue}}">
                            <TextBlock Text="Clear"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Visibility="{Binding StatusMessage.Length, Converter={StaticResource VisibleWhenTrue}}"/>

                    <!-- Test output card — hidden when empty -->
                    <Border Margin="0,10,0,0" Padding="12"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TestOutput}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding TestOutput}"
                                   FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                    </Border>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Account Switching ──────────────────────────────────────── -->
            <TextBlock Text="ACCOUNT SWITCHING" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="Switch between multiple Tailscale accounts if you have more than one."/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                  materialDesign:HintAssist.Hint="Select account"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"/>
                        <Button Grid.Column="1" Margin="0,0,8,0"
                                Command="{Binding RefreshAccountsCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="36" Height="36" ToolTip="Refresh accounts">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding SwitchAccountCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="14,8">
                            <TextBlock Text="Switch"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
