<UserControl x:Class="ScalyTails.Views.SubnetRoutesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:vm="clr-namespace:ScalyTails.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <materialDesign:PackIcon Kind="RouterNetwork" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Subnet Routers"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Margin="0,0,0,20" TextWrapping="Wrap"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Text="Advertise CIDR ranges to make them reachable by your Tailnet. Requires Tailscale admin approval."/>

            <!-- ── Advertise Routes ─────────────────────────────────────────── -->
            <TextBlock Text="ADVERTISED ROUTES"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Margin="0,0,0,8"/>

            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>

                    <!-- Add Route Input -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="CIDR (e.g. 192.168.1.0/24)"
                                 Text="{Binding NewRouteInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddRouteCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding AddRouteCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                ToolTip="Add route" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Add"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Routes List -->
                    <ItemsControl ItemsSource="{Binding AdvertisedRoutes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SubnetRouteViewModel}">
                                <Border Margin="0,0,0,4" Padding="12,8"
                                        CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="NetworkOutline"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                  Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Cidr}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding DataContext.RemoveRouteCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Remove route" Width="32" Height="32">
                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock Text="No routes advertised. Add a CIDR above."
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AdvertisedRoutes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Apply button -->
                    <Button Command="{Binding ApplyRoutesCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CloudUpload" Margin="0,0,8,0"
                                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Apply Routes"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Accept Routes ───────────────────────────────────────────── -->
            <TextBlock Text="INCOMING ROUTES"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Margin="0,0,0,8"/>

            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Accept Subnet Routes"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   FontWeight="Medium"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="Accept routes advertised by peers. When enabled, traffic to those CIDRs is routed through the advertising peer."/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"
                                  IsChecked="{Binding AcceptRoutes}"
                                  Command="{Binding ToggleAcceptRoutesCommand}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                </Grid>
            </materialDesign:Card>

            <!-- ── Advertise as Exit Node ─────────────────────────────────── -->
            <TextBlock Text="EXIT NODE"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Margin="0,0,0,8"/>

            <materialDesign:Card Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Advertise as Exit Node"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   FontWeight="Medium"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="Allow peers to route all internet traffic through this device. Requires admin approval in the Tailscale console."/>
                        <!-- Warning -->
                        <Border Margin="0,10,0,0" Padding="10,8" CornerRadius="4"
                                Background="#1AFF9800"
                                Visibility="{Binding AdvertiseExitNode, Converter={StaticResource VisibleWhenTrue}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertOutline" VerticalAlignment="Center"
                                                          Foreground="#FFFF9800" Margin="0,0,8,0"/>
                                <TextBlock Text="Your device is advertising as an exit node. Peers can route traffic through you."
                                           Foreground="#FFFF9800" TextWrapping="Wrap"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <ToggleButton Grid.Column="1" VerticalAlignment="Top" Margin="16,0,0,0"
                                  IsChecked="{Binding AdvertiseExitNode}"
                                  Command="{Binding ToggleAdvertiseExitNodeCommand}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                </Grid>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
