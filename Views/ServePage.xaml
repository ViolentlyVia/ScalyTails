<UserControl x:Class="ScalyTails.Views.ServePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:vm="clr-namespace:ScalyTails.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <materialDesign:PackIcon Kind="ServerNetwork" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Serve &amp; Funnel"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Margin="0,0,0,20" TextWrapping="Wrap"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Text="Expose local services to your tailnet (Serve) or to the public internet (Funnel)."/>

            <!-- ── Add Serve ──────────────────────────────────────────────── -->
            <TextBlock Text="ADD SERVICE"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Margin="0,0,0,8"/>

            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Protocol -->
                        <ComboBox Grid.Column="0" Margin="0,0,10,0"
                                  materialDesign:HintAssist.Hint="Protocol"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding ServeProtocols}"
                                  SelectedItem="{Binding NewServeProtocol}"/>

                        <!-- Port -->
                        <TextBox Grid.Column="1" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Port"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NewServePort, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddServeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Target -->
                        <TextBox Grid.Column="2" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Target (e.g. http://localhost:3000)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NewServeTarget, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddServeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Add button -->
                        <Button Grid.Column="3"
                                Command="{Binding AddServeCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Add"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="HTTPS Funnel exposes the service to the public internet via Tailscale."/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Active Serve Configs ───────────────────────────────────── -->
            <TextBlock Text="ACTIVE CONFIGS"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Margin="0,0,0,8"/>

            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>

                    <ItemsControl ItemsSource="{Binding ServeEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ServeEntryViewModel}">
                                <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Protocol chip -->
                                        <Border Grid.Column="0" CornerRadius="10" Padding="8,3"
                                                Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FunnelEnabled}" Value="True">
                                                            <Setter Property="Background" Value="#FF6A1B9A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Protocol}" FontSize="11"
                                                       FontWeight="Medium" Foreground="White"/>
                                        </Border>

                                        <!-- Funnel badge -->
                                        <materialDesign:PackIcon Grid.Column="1" Kind="Web"
                                            Width="18" Height="18" VerticalAlignment="Center"
                                            Foreground="#FF6A1B9A" Margin="0,0,8,0"
                                            ToolTip="Publicly accessible via Funnel"
                                            Visibility="{Binding FunnelEnabled, Converter={StaticResource VisibleWhenTrue}}"/>

                                        <!-- Label -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayLabel}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"/>

                                        <!-- Remove button -->
                                        <Button Grid.Column="3"
                                                Command="{Binding DataContext.RemoveServeEntryCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Remove" Width="32" Height="32">
                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock Text="No active serve configs."
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServeEntries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Reset button -->
                    <Button Command="{Binding ResetServeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Right" Margin="0,8,0,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DeleteSweep" Margin="0,0,6,0"
                                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Reset All"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Info Cards ─────────────────────────────────────────────── -->
            <UniformGrid Rows="1" Columns="2" Margin="0,0,0,0">
                <materialDesign:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Lock" Width="20" Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Serve (tailnet only)"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="HTTPS and HTTP expose local services to peers within your tailnet. Only authenticated Tailscale users can reach them."/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Web" Width="20" Height="20"
                                                     Foreground="#FF6A1B9A"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Funnel (public internet)"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="HTTPS Funnel makes local services publicly accessible via a Tailscale-provisioned HTTPS URL. Requires Funnel enabled in your tailnet policy."/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
