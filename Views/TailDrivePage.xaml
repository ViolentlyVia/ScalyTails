<UserControl x:Class="ScalyTails.Views.TailDrivePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:vm="clr-namespace:ScalyTails.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <materialDesign:PackIcon Kind="FolderNetwork" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Taildrive" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Margin="0,0,0,20" TextWrapping="Wrap"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Text="Share local folders with other devices on your tailnet. Peers access them via WebDAV at https://&lt;node&gt;/v1/shares."/>

            <TextBlock Text="SHARE A FOLDER" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Share name"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NewShareName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="1" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="Local folder path"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NewSharePath, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                        <Button Grid.Column="2" Margin="0,0,8,0"
                                Command="{Binding BrowsePathCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="10,8" ToolTip="Browse for folder">
                            <materialDesign:PackIcon Kind="FolderOpen"/>
                        </Button>
                        <Button Grid.Column="3"
                                Command="{Binding AddShareCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Share"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Visibility="{Binding StatusMessage.Length, Converter={StaticResource VisibleWhenTrue}}"/>
                </StackPanel>
            </materialDesign:Card>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ACTIVE SHARES"
                           Style="{StaticResource MaterialDesignOverlineTextBlock}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32"
                        ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                </Button>
            </Grid>

            <materialDesign:Card Padding="16">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Shares}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DriveShareEntry}">
                                <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="FolderShared"
                                            Width="20" Height="20" VerticalAlignment="Center"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontWeight="Medium" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Path}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="3"
                                                Command="{Binding DataContext.RemoveShareCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32" ToolTip="Remove share">
                                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No folders are currently shared."
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Shares.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
