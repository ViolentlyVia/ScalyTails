<UserControl x:Class="ScalyTails.Views.ExitNodesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:vm="clr-namespace:ScalyTails.ViewModels">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="OnlineBrush"
            TrueColor="#FF4CAF50" FalseColor="#FF616161"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>

        <!-- ListBox item container: remove default WPF selection chrome -->
        <Style x:Key="ExitNodeItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <materialDesign:PackIcon Kind="Directions" Width="24" Height="24"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Exit Nodes"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Route your internet traffic through a peer. Only peers advertising exit node capability are listed."
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Active Exit Node Banner (shown when a real exit node is selected) -->
        <materialDesign:Card Grid.Row="1" Margin="0,8,0,12" Padding="14"
                             Background="{DynamicResource PrimaryHueLightBrush}"
                             Visibility="{Binding IsExitNodeActive, Converter={StaticResource VisibleWhenTrue}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CheckCircle" VerticalAlignment="Center"
                                         Foreground="White" Width="20" Height="20" Margin="0,0,10,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="White">
                    <Run Text="Routing via "/>
                    <Run Text="{Binding ActiveExitNodeName}" FontWeight="Bold"/>
                </TextBlock>
                <Button Margin="16,0,0,0" Command="{Binding ClearExitNodeCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White" BorderBrush="White" Height="28" Padding="8,0">
                    <TextBlock Text="Clear" FontSize="12"/>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- Exit Node List (ListBox handles selection tracking automatically) -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding ExitNodes}"
                 SelectedItem="{Binding SelectedExitNode}"
                 ItemContainerStyle="{StaticResource ExitNodeItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ExitNodeViewModel}">
                    <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Colored left accent when selected -->
                            <Border Grid.Column="0" Width="4" CornerRadius="2,0,0,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected,
                                                RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource PrimaryHueMidBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Content -->
                            <Grid Grid.Column="1" Margin="14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- OS / None Icon -->
                                <materialDesign:PackIcon Grid.Column="0"
                                    Kind="{Binding OsIcon}" Width="28" Height="28"
                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                    Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="Medium"
                                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                        <!-- Online dot (hidden for None item) -->
                                        <Ellipse Width="8" Height="8" Margin="8,0,0,0"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsNone, Converter={StaticResource VisibleWhenFalse}}"
                                                 Fill="{Binding Online, Converter={StaticResource OnlineBrush}}"/>
                                    </StackPanel>
                                    <!-- IP (hidden for None item) -->
                                    <TextBlock Text="{Binding PrimaryIP}"
                                               FontFamily="Consolas" FontSize="12"
                                               Visibility="{Binding IsNone, Converter={StaticResource VisibleWhenFalse}}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <!-- Caption for None item -->
                                    <TextBlock Text="Traffic goes directly to its destination"
                                               FontSize="12"
                                               Visibility="{Binding IsNone, Converter={StaticResource VisibleWhenTrue}}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Checkmark for selected item -->
                            <materialDesign:PackIcon Grid.Column="2" Kind="Check" Width="20" Height="20"
                                                      VerticalAlignment="Center" Margin="0,0,14,0"
                                                      Foreground="{DynamicResource PrimaryHueMidBrush}">
                                <materialDesign:PackIcon.Visibility>
                                    <Binding Path="IsSelected"
                                             RelativeSource="{RelativeSource AncestorType=ListBoxItem}">
                                        <Binding.Converter>
                                            <converters:BoolToVisibilityConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </materialDesign:PackIcon.Visibility>
                            </materialDesign:PackIcon>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Apply + Options footer -->
        <materialDesign:Card Grid.Row="3" Margin="0,12,0,0" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LAN access toggle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding AllowLanAccess}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Allow LAN access"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                        <TextBlock Text="Keep access to local devices while using exit node"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding ApplyExitNodeCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Padding="20,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Apply"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
