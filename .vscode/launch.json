{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ScalyTails Web (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/ScalyTails.Web/bin/Debug/net10.0/ScalyTails.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/ScalyTails.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}"
      }
    }
  ]
}
