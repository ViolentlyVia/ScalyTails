<UserControl x:Class="ScalyTails.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="OnlineColor"
            TrueColor="#FF4CAF50" FalseColor="#FF9E9E9E"/>
        <converters:BoolToStringConverter x:Key="ConnectText"
            TrueValue="Disconnect" FalseValue="Connect"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="680">

            <!-- Not Installed Banner -->
            <materialDesign:Card
                Visibility="{Binding TailscaleInstalled, Converter={StaticResource VisibleWhenFalse}}"
                Background="#FFB71C1C" Margin="0,0,0,16" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" VerticalAlignment="Center"
                                            Foreground="White" Width="28" Height="28" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Tailscale Not Found" FontWeight="Bold" Foreground="White" FontSize="16"/>
                        <TextBlock Text="Install Tailscale from tailscale.com/download and restart this app."
                                   Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Needs Login Banner -->
            <materialDesign:Card
                Visibility="{Binding NeedsLogin, Converter={StaticResource VisibleWhenTrue}}"
                Background="#FFF57F17" Margin="0,0,0,16" Padding="16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Login" VerticalAlignment="Center"
                                            Foreground="White" Width="28" Height="28" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Login Required" FontWeight="Bold" Foreground="White" FontSize="16"/>
                        <TextBlock Text="Run 'tailscale up' in a terminal or click Connect to authenticate."
                                   Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Connection Status Card -->
            <materialDesign:Card Margin="0,0,0,16" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Status Indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="14" Height="14" Margin="0,0,10,0" VerticalAlignment="Center"
                                     Fill="{Binding IsRunning, Converter={StaticResource OnlineColor}}"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Self hostname -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                            <materialDesign:PackIcon Kind="Laptop" VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelfHostName}"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                        </StackPanel>

                        <!-- IPs -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                            <materialDesign:PackIcon Kind="Ip" VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelfIPs}" FontFamily="Consolas"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </StackPanel>

                        <!-- Tailnet -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                            <materialDesign:PackIcon Kind="NetworkOutline" VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding TailnetName}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Connect / Disconnect Button -->
                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Command="{Binding ToggleConnectionCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Width="130" Height="44">
                        <StackPanel Orientation="Horizontal">
                            <!-- Disconnect icon (shown when connected) -->
                            <materialDesign:PackIcon Kind="LinkVariantOff" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}"/>
                            <!-- Connect icon (shown when disconnected) -->
                            <materialDesign:PackIcon Kind="LinkVariant" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenFalse}}"/>
                            <TextBlock Text="{Binding IsRunning, Converter={StaticResource ConnectText}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Stats Row -->
            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,16"
                         Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                <!-- Peers online -->
                <materialDesign:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="AccountMultiple" Width="28" Height="28"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding OnlinePeerCount}"
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="Peers Online"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Exit Node -->
                <materialDesign:Card Margin="0,0,8,0" Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Directions" Width="28" Height="28"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ActiveExitNodeName}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                        <TextBlock Text="Exit Node"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Routes Advertised -->
                <materialDesign:Card Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="RouterNetwork" Width="28" Height="28"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AdvertisedRoutes.Count}"
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="Subnet Routes"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Quick Settings Card -->
            <materialDesign:Card Padding="16"
                                 Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                <StackPanel>
                    <TextBlock Text="Quick Settings"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12"/>

                    <!-- Shields Up -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Shields Up"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            <TextBlock Text="Block all incoming connections"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding ShieldsUp}"
                                      Command="{Binding ToggleShieldsUpCommand}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    </Grid>

                    <Separator Margin="0,4"/>

                    <!-- Accept Routes -->
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Accept Subnet Routes"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            <TextBlock Text="Accept advertised routes from peers"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding AcceptRoutes}"
                                      Command="{Binding ToggleAcceptRoutesCommand}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    </Grid>

                    <Separator Margin="0,4"/>

                    <!-- Advertise as Exit Node -->
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Advertise as Exit Node"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            <TextBlock Text="Allow others to route traffic through this device"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding AdvertiseExitNode}"
                                      Command="{Binding ToggleAdvertiseExitNodeCommand}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    </Grid>

                    <Separator Margin="0,4"/>

                    <!-- MagicDNS -->
                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MagicDNS"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            <TextBlock Text="Use Tailscale DNS to resolve peer hostnames"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding AcceptDns}"
                                      Command="{Binding ToggleAcceptDnsCommand}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    </Grid>

                    <Separator Margin="0,4"/>

                    <!-- SSH Server -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SSH Server"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            <TextBlock Text="Allow peers to SSH into this device via Tailscale"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" VerticalAlignment="Center"
                                      IsChecked="{Binding SshServerEnabled}"
                                      Command="{Binding ToggleSshServerCommand}"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Version footer -->
            <TextBlock Text="{Binding Version, StringFormat='Tailscale {0}'}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Margin="0,12,0,0" HorizontalAlignment="Right"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
