<UserControl x:Class="ScalyTails.Views.DnsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="680">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Dns" Width="24" Height="24" VerticalAlignment="Center"
                                             Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="DNS" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,6"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Load"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- No API key warning -->
            <materialDesign:Card Background="#FFB71C1C" Margin="0,0,0,16" Padding="14"
                                  Visibility="{Binding HasApiKey, Converter={StaticResource VisibleWhenFalse}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="API key required. Go to Settings to add one." Foreground="White"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- MagicDNS -->
            <TextBlock Text="MAGIC DNS" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Enable MagicDNS" Style="{StaticResource MaterialDesignBody1TextBlock}" FontWeight="Medium"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="Automatically register DNS names for all devices in your tailnet."/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"
                                  IsChecked="{Binding MagicDnsEnabled}"
                                  Command="{Binding ToggleMagicDnsCommand}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                </Grid>
            </materialDesign:Card>

            <!-- Nameservers -->
            <TextBlock Text="NAMESERVERS" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="e.g. 1.1.1.1"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontFamily="Consolas"
                                 Text="{Binding NewNameserver, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddNameserverCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding AddNameserverCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Padding="12,8">
                            <materialDesign:PackIcon Kind="Plus"/>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Nameservers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="10,8" CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.RemoveNameserverCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28">
                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding ApplyNameserversCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Right" Margin="0,8,0,0" Padding="16,6"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="Apply"/>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- Search Paths -->
            <TextBlock Text="SEARCH PATHS" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,0,0,8"/>
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,10,0"
                                 materialDesign:HintAssist.Hint="e.g. corp.example.com"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" FontFamily="Consolas"
                                 Text="{Binding NewSearchPath, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddSearchPathCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding AddSearchPathCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Padding="12,8">
                            <materialDesign:PackIcon Kind="Plus"/>
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding SearchPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="10,8" CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.RemoveSearchPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28">
                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding ApplySearchPathsCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Right" Margin="0,8,0,0" Padding="16,6"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="Apply"/>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Visibility="{Binding StatusMessage.Length, Converter={StaticResource VisibleWhenTrue}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
