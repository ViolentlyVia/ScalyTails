<UserControl x:Class="ScalyTails.Views.PolicyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8,8,8,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ShieldAccount" Width="24" Height="24" VerticalAlignment="Center"
                                         Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="ACL Policy" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="14,6"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Load"/>
                </StackPanel>
            </Button>
        </Grid>

        <materialDesign:Card Background="#FFB71C1C" Grid.Row="1" Margin="8,0,8,12" Padding="14"
                              Visibility="{Binding HasApiKey, Converter={StaticResource VisibleWhenFalse}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="API key required. Go to Settings to add one." Foreground="White"
                           Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,8">
            <Button Command="{Binding SavePolicyCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="14,6"
                    IsEnabled="{Binding IsDirty}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Save"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding RevertPolicyCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Padding="14,6"
                    IsEnabled="{Binding IsDirty}" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Undo" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Revert"/>
                </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsDirty, Converter={StaticResource VisibleWhenTrue}}">
                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#FFFF9800"
                                         Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="Unsaved changes" Foreground="#FFFF9800"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="3" Margin="8,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1" CornerRadius="4">
            <TextBox Text="{Binding PolicyText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" AcceptsTab="True"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Padding="10"
                     Background="Transparent"
                     BorderThickness="0"
                     VerticalContentAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
