<UserControl x:Class="ScalyTails.Views.DevicesAdminPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScalyTails.Converters"
             xmlns:models="clr-namespace:ScalyTails.Models">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:BoolToColorConverter x:Key="AuthBrush" TrueColor="#FF4CAF50" FalseColor="#FFFF9800"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8,8,8,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Devices" Width="24" Height="24" VerticalAlignment="Center"
                                         Margin="0,0,10,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Devices" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" Padding="14,6"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Load"/>
                </StackPanel>
            </Button>
        </Grid>

        <materialDesign:Card Background="#FFB71C1C" Grid.Row="1" Margin="8,0,8,12" Padding="14"
                              Visibility="{Binding HasApiKey, Converter={StaticResource VisibleWhenFalse}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="API key required. Go to Settings to add one." Foreground="White"
                           Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Filter + status -->
        <Grid Grid.Row="1" Margin="8,0,8,8"
              Visibility="{Binding IsLoaded, Converter={StaticResource VisibleWhenTrue}}">
            <TextBox materialDesign:HintAssist.Hint="Filter by name, user, or IP…"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Devices}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" SelectionMode="Single"
                  materialDesign:DataGridAssist.CellPadding="10 6 10 6"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="10 6 10 6"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Auth" Width="50" SortMemberPath="Authorized">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:ApiDevice}">
                            <materialDesign:PackIcon
                                Kind="{Binding Authorized, Converter={x:Static converters:BoolToIconConverter.Instance}}"
                                Width="18" Height="18" HorizontalAlignment="Center"
                                Foreground="{Binding Authorized, Converter={StaticResource AuthBrush}}"
                                ToolTip="{Binding Authorized}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Name" Binding="{Binding ShortName}" Width="*" FontWeight="Medium"/>
                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="*"/>
                <DataGridTextColumn Header="IP" Binding="{Binding PrimaryAddress}" Width="130" FontFamily="Consolas"/>
                <DataGridTextColumn Header="OS" Binding="{Binding OS}" Width="80"/>
                <DataGridTextColumn Header="Version" Binding="{Binding ClientVersion}" Width="90" FontFamily="Consolas"/>

                <DataGridTemplateColumn Header="Key Expiry" Width="90" SortMemberPath="ExpiryStatus">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:ApiDevice}">
                            <TextBlock Text="{Binding ExpiryStatus}" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpiringSoon}" Value="True">
                                                <Setter Property="Foreground" Value="#FFFF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                <Setter Property="Foreground" Value="#FFB71C1C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Tags" Binding="{Binding TagsDisplay}" Width="120" FontSize="12"/>

                <DataGridTextColumn Header="Last Seen"
                                    Binding="{Binding LastSeen, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                    Width="130" FontSize="12"/>

                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:ApiDevice}">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32" Padding="0"
                                        ToolTip="Authorize device"
                                        Visibility="{Binding Authorized, Converter={StaticResource VisibleWhenFalse}}"
                                        Command="{Binding DataContext.AuthorizeDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" Foreground="#FF4CAF50"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32" Padding="0" ToolTip="Expire key"
                                        Command="{Binding DataContext.ExpireKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="KeyRemove" Width="16" Height="16"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32" Padding="0" ToolTip="Remove device"
                                        Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Foreground="#FFEF5350"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
