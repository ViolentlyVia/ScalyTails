<Window x:Class="ScalyTails.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:ScalyTails.Converters"
        Title="ScalyTails" Height="680" Width="900"
        MinWidth="720" MinHeight="520"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="OnlineBrush"
            TrueColor="#FF4CAF50" FalseColor="#FF9E9E9E"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue"/>

        <!-- Self-contained nav button style — no dependency on MaterialDesignNavigationRailButton -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Nav"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" BorderThickness="0">
                            <!-- Left accent bar for active state -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle x:Name="Accent" Grid.Column="0"
                                           Fill="{DynamicResource PrimaryHueMidBrush}"
                                           Opacity="0"/>
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="0,8"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MaterialDesignSelection}"/>
                                <Setter TargetName="Accent" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource MaterialDesignDivider}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavGroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            <Setter Property="Margin" Value="16,10,0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title / App Bar ─────────────────────────────────────────────── -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Network" Width="28" Height="28"
                                             VerticalAlignment="Center" Margin="0,0,10,0"
                                             Foreground="White"/>
                    <TextBlock Text="ScalyTails" VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TailnetName, StringFormat=' · {0}'}"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Foreground="#CCFFFFff" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Status pill -->
                <Border Grid.Column="1" HorizontalAlignment="Center"
                        Background="#22000000" CornerRadius="12" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Fill="{Binding IsRunning, Converter={StaticResource OnlineBrush}}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Busy spinner -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Width="20" Height="20" IsIndeterminate="True"
                                     Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding BusyMessage}" Foreground="#CCFFFFff"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Command="{Binding RefreshCommand}"
                            Foreground="White" ToolTip="Refresh status">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Command="{Binding LogoutCommand}"
                            Foreground="White" ToolTip="Logout from Tailscale"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                        <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- ── Navigation + Content ───────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Nav sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8">

                        <TextBlock Text="NETWORK" Style="{StaticResource NavGroupLabel}"/>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     IsChecked="True"
                                     Click="NavButton_Click" Tag="Overview">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Overview" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Peers">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountMultiple" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Peers" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="ExitNodes">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Directions" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Exit Nodes" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="SubnetRoutes">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="RouterNetwork" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Subnet Routes" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Serve">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ServerNetwork" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Serve" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="8,4"/>
                        <TextBlock Text="TOOLS" Style="{StaticResource NavGroupLabel}"/>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Diagnostics">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Pulse" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Diagnostics" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="TailDrive">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FolderNetwork" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="TailDrive" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="8,4"/>
                        <TextBlock Text="ADMIN" Style="{StaticResource NavGroupLabel}"/>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Devices">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Devices" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Devices" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Users">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Users" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="DNS">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Dns" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="DNS" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Policy">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ShieldAccount" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Policy" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Logs">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FormatListBulleted" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Logs" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Keys">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Key" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Auth Keys" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                        <Border Height="1" Background="{DynamicResource MaterialDesignDivider}" Margin="8,4"/>
                        <TextBlock Text="ACCOUNT" Style="{StaticResource NavGroupLabel}"/>

                        <RadioButton Style="{StaticResource NavButtonStyle}"
                                     Click="NavButton_Click" Tag="Settings">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Settings" FontSize="11" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Page host -->
            <ContentPresenter Grid.Column="1" x:Name="PageHost"/>
        </Grid>

        <!-- ── Status Bar ──────────────────────────────────────────────────── -->
        <materialDesign:ColorZone Grid.Row="2" Mode="Dark" Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding SelfIPs}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           FontFamily="Consolas"
                           Foreground="#AAFFFFff" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Version, StringFormat='Tailscale v{0}'}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Foreground="#66FFFFff" VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:ColorZone>
    </Grid>
</Window>
